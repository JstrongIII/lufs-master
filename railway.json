{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacks": {
      "玄uildCommand": "cd backend && pip install -r requirements.txt",
      "install": [
        "apt-get update && apt-get install -y ffmpeg"
      ]
    },
    "src": "./backend"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}